###############################################################################
# Project Management MERN — Root Environment Variables
# Copy this file to .env and fill in the values
#   cp .env.example .env
###############################################################################

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_strong_password
MONGO_DB=project_management
MONGO_PORT=27017

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_PORT=6379

# ── Server ────────────────────────────────────────────────────────────────────
# REQUIRED: generate with: openssl rand -base64 64
JWT_SECRET=changeme_super_secret_jwt_key

# ── Client ────────────────────────────────────────────────────────────────────
CLIENT_PORT=80
